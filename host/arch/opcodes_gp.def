// LITTLE64_GP_OPCODE(enum_name, opcode_value, mnemonic_string, encoding)
// encoding: GP::Encoding value — 0=NONE, 1=RD, 2=RS1_RD, 3=IMM4_RD
// Format 110 instructions (bits[15:13]=110): 5-bit opcode space for GP ALU operations
LITTLE64_GP_OPCODE(ADD,  0, "ADD",  2)
LITTLE64_GP_OPCODE(SUB,  1, "SUB",  2)
LITTLE64_GP_OPCODE(TEST, 2, "TEST", 2)

// Atomic load-linked / store-conditional for synchronization primitives
LITTLE64_GP_OPCODE(LLR,  3, "LLR",  2) // Load-linked: Rd = MEM64[Rs1], set reservation
LITTLE64_GP_OPCODE(SCR,  4, "SCR",  2) // Store-conditional: if reservation valid, MEM64[Rs1] = Rd; Z = reservation_valid

LITTLE64_GP_OPCODE(AND,  16, "AND", 2)
LITTLE64_GP_OPCODE(OR,   17, "OR",  2)
LITTLE64_GP_OPCODE(XOR,  18, "XOR", 2)
LITTLE64_GP_OPCODE(SLL,  20, "SLL", 2)
LITTLE64_GP_OPCODE(SRL,  21, "SRL", 2)
LITTLE64_GP_OPCODE(SRA,  22, "SRA", 2)

// Immediate-shift variants: Rs1 field holds a 4-bit literal shift count (0–15)
LITTLE64_GP_OPCODE(SLLI, 23, "SLLI", 3)
LITTLE64_GP_OPCODE(SRLI, 24, "SRLI", 3)
LITTLE64_GP_OPCODE(SRAI, 25, "SRAI", 3)

// System call instruction: triggers TRAP_SYSCALL (64) in user mode, TRAP_SYSCALL_FROM_SUPERVISOR (65) in supervisor
LITTLE64_GP_OPCODE(SYSCALL, 27, "SYSCALL", 0)

// Opcodes >= 28 are defined as "special"; while they are in ALU space,
// they have non-ALU effects.
LITTLE64_GP_OPCODE(LSR, 28, "LSR", 2) // Load special register; load the special register by ID in Rs1 into Rd
LITTLE64_GP_OPCODE(SSR, 29, "SSR", 2) // Store special register; store the value in Rd into the special register by ID in Rs1

// Opcodes >= 30 are no-operand instructions
LITTLE64_GP_OPCODE(IRET, 30, "IRET", 0)

// Emulator-specifc instruction: stop emulation
LITTLE64_GP_OPCODE(STOP, 31, "STOP", 0)