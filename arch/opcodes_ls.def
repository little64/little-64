// LITTLE64_LS_OPCODE(enum_name, opcode_value, mnemonic_string)
// Formats 00 and 01 instructions: 4-bit opcode space for load/store/move/jump operations
LITTLE64_LS_OPCODE(LOAD,        0,  "LOAD")
LITTLE64_LS_OPCODE(STORE,       1,  "STORE")
LITTLE64_LS_OPCODE(INC_LOAD,    2,  "INC_LOAD")
LITTLE64_LS_OPCODE(DEC_STORE,   3,  "DEC_STORE")
LITTLE64_LS_OPCODE(MOVE,        4,  "MOVE")
LITTLE64_LS_OPCODE(BYTE_LOAD,   5,  "BYTE_LOAD")
LITTLE64_LS_OPCODE(BYTE_STORE,  6,  "BYTE_STORE")
LITTLE64_LS_OPCODE(SHORT_LOAD,  7,  "SHORT_LOAD")
LITTLE64_LS_OPCODE(SHORT_STORE, 8,  "SHORT_STORE")
LITTLE64_LS_OPCODE(WORD_LOAD,   9,  "WORD_LOAD")
LITTLE64_LS_OPCODE(WORD_STORE,  10, "WORD_STORE")
LITTLE64_LS_OPCODE(JUMP_Z,      11, "JUMP.Z")
LITTLE64_LS_OPCODE(JUMP_C,      12, "JUMP.C")
LITTLE64_LS_OPCODE(JUMP_S,      13, "JUMP.S")
LITTLE64_LS_OPCODE(JUMP_GT,     14, "JUMP.GT")
LITTLE64_LS_OPCODE(JUMP_LT,     15, "JUMP.LT")
