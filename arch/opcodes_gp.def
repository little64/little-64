// LITTLE64_GP_OPCODE(enum_name, opcode_value, mnemonic_string, num_regs)
// num_regs: 2 = Rs1+Rd, 1 = Rd only (Rs1 ignored), 0 = no registers (both ignored)
// Format 11 instructions (bits[15:14]=11): 6-bit opcode space for GP ALU operations
LITTLE64_GP_OPCODE(ADD,  0, "ADD",  2)
LITTLE64_GP_OPCODE(SUB,  1, "SUB",  2)
LITTLE64_GP_OPCODE(TEST, 2, "TEST", 2)

LITTLE64_GP_OPCODE(AND,  16, "AND", 2)
LITTLE64_GP_OPCODE(OR,   17, "OR",  2)
LITTLE64_GP_OPCODE(XOR,  18, "XOR", 2)
LITTLE64_GP_OPCODE(SLL,  20, "SLL", 2)
LITTLE64_GP_OPCODE(SRL,  21, "SRL", 2)
LITTLE64_GP_OPCODE(SRA,  22, "SRA", 2)


// Opcodes >= 56 are defined as "special"; while they are in ALU space,
// they have non-ALU effects.
LITTLE64_GP_OPCODE(LSR, 56, "LSR", 2) // Load special register; load the special register by ID in Rs1 into Rd
LITTLE64_GP_OPCODE(SSR, 57, "SSR", 2) // Store special register; store the value in Rd into the special register by ID in Rs1

// Opcodes >= 60 are no-operand instructions
LITTLE64_GP_OPCODE(IRET, 60, "IRET", 0)

// Emulator-specifc instruction: stop emulation
LITTLE64_GP_OPCODE(STOP, 63, "STOP", 0)