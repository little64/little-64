LITTLE64_LDI_CASE(0, 0x00, 1, 0xFFFFFFFFFFFFFFFF, 0x0, 0x0, 0x0, "LDI #0 clears register")
LITTLE64_LDI_CASE(0, 0x01, 1, 0xFFFF, 0x1, 0x0, 0x0, "LDI #1 replaces register")
LITTLE64_LDI_CASE(0, 0xFF, 1, 0x0, 0xFF, 0x0, 0x0, "LDI #255 max immediate")
LITTLE64_LDI_CASE(0, 0x42, 1, 0xDEAD, 0x42, 0x0, 0x0, "LDI #0x42 replaces old value")

LITTLE64_LDI_CASE(1, 0xAB, 1, 0x0, 0xAB00, 0x0, 0x0, "LDI.S1 OR into byte 1")
LITTLE64_LDI_CASE(1, 0xAB, 1, 0x55, 0xAB55, 0x0, 0x0, "LDI.S1 preserves low byte")
LITTLE64_LDI_CASE(1, 0xAB, 1, 0xFF00, 0xFF00, 0x0, 0x0, "LDI.S1 OR semantics")

LITTLE64_LDI_CASE(2, 0xCD, 1, 0x0, 0xCD0000, 0x0, 0x0, "LDI.S2 OR into byte 2")
LITTLE64_LDI_CASE(2, 0xCD, 1, 0x1234, 0xCD1234, 0x0, 0x0, "LDI.S2 preserves low bytes")

LITTLE64_LDI_CASE(3, 0x7F, 1, 0x0, 0x7F000000, 0x0, 0x0, "LDI.S3 positive no sign extend")
LITTLE64_LDI_CASE(3, 0x80, 1, 0x0, 0xFFFFFFFF80000000, 0x0, 0x0, "LDI.S3 sign extends 0x80")
LITTLE64_LDI_CASE(3, 0x80, 1, 0x1234, 0xFFFFFFFF80001234, 0x0, 0x0, "LDI.S3 sign extend preserves low bytes")
LITTLE64_LDI_CASE(3, 0xFF, 1, 0x0, 0xFFFFFFFFFF000000, 0x0, 0x0, "LDI.S3 sign extends 0xFF")

LITTLE64_LDI_CASE(0, 0x00, 3, 0x0, 0x0, 0x0, 0x0, "LDI does not set flags when clear")
LITTLE64_LDI_CASE(0, 0x2A, 3, 0x0, 0x2A, 0x2, 0x2, "LDI preserves carry flag")
