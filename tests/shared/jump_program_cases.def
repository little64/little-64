LITTLE64_PROGRAM_REGS_CASE("JUMP.Z taken when Z=1", "LDI #5, R2\nLDI #5, R3\nSUB R3, R2\nJUMP.Z @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.Z not taken when Z=0", "LDI #5, R2\nLDI #3, R3\nSUB R3, R2\nJUMP.Z @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.C taken when C=1", "LDI #3, R2\nLDI #5, R3\nSUB R3, R2\nJUMP.C @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.C not taken when C=0", "LDI #5, R2\nLDI #3, R3\nSUB R3, R2\nJUMP.C @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.C taken on ADD overflow", "LDI #0, R2\nLDI #1, R3\nSUB R3, R2\nADD R3, R2\nJUMP.C @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.S taken when S=1", "LDI #0, R2\nLDI #1, R3\nSUB R3, R2\nJUMP.S @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.S not taken when S=0", "LDI #5, R2\nLDI #3, R3\nSUB R3, R2\nJUMP.S @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.GT taken on positive result", "LDI #5, R2\nLDI #3, R3\nSUB R3, R2\nJUMP.GT @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.GT not taken on zero", "LDI #5, R2\nLDI #5, R3\nSUB R3, R2\nJUMP.GT @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.GT not taken when S=1", "LDI #0, R2\nLDI #1, R3\nSUB R3, R2\nJUMP.GT @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.LT taken when S=1", "LDI #0, R2\nLDI #1, R3\nSUB R3, R2\nJUMP.LT @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.LT not taken when S=0", "LDI #7, R2\nLDI #3, R3\nSUB R3, R2\nJUMP.LT @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP.LT not taken on zero", "LDI #4, R2\nLDI #4, R3\nSUB R3, R2\nJUMP.LT @taken\nLDI #2, R1\nJUMP @end\ntaken:\nLDI #1, R1\nend:\nSTOP\n", 1, 2, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("JUMP unconditional skips instruction", "JUMP @skip\nLDI #2, R1\nskip:\nLDI #1, R1\nSTOP\n", 1, 1, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("Backward loop executes five iterations", "LDI #5, R1\nLDI #0, R2\nloop:\nLDI #1, R3\nADD R3, R2\nSUB R3, R1\nJUMP.Z @done\nJUMP @loop\ndone:\nSTOP\n", 1, 0, 2, 5, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("Forward skip leaves value unchanged", "LDI #42, R1\nJUMP @skip\nLDI #99, R1\nskip:\nSTOP\n", 1, 42, -1, 0, -1, 0)
