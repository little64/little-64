LITTLE64_PROGRAM_REGS_CASE("STORE+LOAD 64 round-trip 0x42", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0x42, R1\nSTORE [R14], R1\nLOAD [R14], R2\nSTOP\n", 2, 0x42, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("STORE+LOAD 64 round-trip zero", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0x00, R1\nSTORE [R14], R1\nLOAD [R14], R2\nSTOP\n", 2, 0x0, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("STORE+LOAD 64 offset +6", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0x55, R1\nSTORE [R14+6], R1\nLOAD [R14+6], R2\nSTOP\n", 2, 0x55, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("STORE+LOAD 64 round-trip all ones", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0, R1\nLDI #1, R3\nSUB R3, R1\nSTORE [R14], R1\nLOAD [R14], R2\nSTOP\n", 2, 0xFFFFFFFFFFFFFFFF, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("BYTE_STORE+BYTE_LOAD round-trip", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0xAB, R1\nBYTE_STORE [R14], R1\nBYTE_LOAD [R14], R2\nSTOP\n", 2, 0xAB, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("BYTE_LOAD zero extends", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0, R1\nLDI #1, R3\nSUB R3, R1\nBYTE_STORE [R14], R1\nBYTE_LOAD [R14], R2\nSTOP\n", 2, 0xFF, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("BYTE_STORE adjacent bytes independent", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0x11, R1\nBYTE_STORE [R14], R1\nLDI #0x22, R1\nBYTE_STORE [R14+2], R1\nBYTE_LOAD [R14], R2\nSTOP\n", 2, 0x11, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("SHORT_STORE+LOAD round-trip", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0xCD, R1\nLDI.S1 #0xAB, R1\nSHORT_STORE [R14], R1\nSHORT_LOAD [R14], R2\nSTOP\n", 2, 0xABCD, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("SHORT_LOAD zero extends", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0, R1\nLDI #1, R3\nSUB R3, R1\nSHORT_STORE [R14], R1\nSHORT_LOAD [R14], R2\nSTOP\n", 2, 0xFFFF, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("WORD_STORE+LOAD round-trip", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0xEF, R1\nLDI.S1 #0xBE, R1\nLDI.S2 #0xAD, R1\nLDI.S3 #0xDE, R1\nWORD_STORE [R14], R1\nWORD_LOAD [R14], R2\nSTOP\n", 2, 0xDEADBEEF, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("WORD_LOAD zero extends", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nLDI #0, R1\nLDI #1, R3\nSUB R3, R1\nWORD_STORE [R14], R1\nWORD_LOAD [R14], R2\nSTOP\n", 2, 0xFFFFFFFF, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("Stack round-trip preserves value and SP", "LDI #0x00, R13\nLDI.S1 #0x20, R13\nLDI #0xBB, R1\nPUSH R1, R13\nPOP R2, R13\nSTOP\n", 2, 0xBB, 13, 0x2000, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("Stack push decrements SP by 8", "LDI #0x00, R13\nLDI.S1 #0x20, R13\nLDI #1, R1\nPUSH R1, R13\nSTOP\n", 13, 0x1FF8, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("Stack pop restores SP", "LDI #0x00, R13\nLDI.S1 #0x20, R13\nLDI #1, R1\nPUSH R1, R13\nPOP R2, R13\nSTOP\n", 13, 0x2000, 2, 0x1, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("Stack LIFO ordering", "LDI #0x00, R13\nLDI.S1 #0x20, R13\nLDI #0xAA, R1\nLDI #0xBB, R2\nPUSH R1, R13\nPUSH R2, R13\nPOP R3, R13\nPOP R4, R13\nSTOP\n", 3, 0xBB, 4, 0xAA, 13, 0x2000)
LITTLE64_PROGRAM_REGS_CASE("MOVE offset 0", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nMOVE R14, R2\nSTOP\n", 2, 0x1000, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("MOVE offset 2", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nMOVE R14+2, R2\nSTOP\n", 2, 0x1002, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("MOVE offset 4", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nMOVE R14+4, R2\nSTOP\n", 2, 0x1004, -1, 0, -1, 0)
LITTLE64_PROGRAM_REGS_CASE("MOVE offset 6", "LDI #0x00, R14\nLDI.S1 #0x10, R14\nMOVE R14+6, R2\nSTOP\n", 2, 0x1006, -1, 0, -1, 0)
